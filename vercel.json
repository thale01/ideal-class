{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://ideal-class-production.up.railway.app/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [ { "key": "Cache-Control", "value": "public, s-maxage=0, max-age=0, must-revalidate" } ]
    },
    {
      "source": "/",
      "headers": [ { "key": "Cache-Control", "value": "public, s-maxage=0, max-age=0, must-revalidate" } ]
    }
  ]
}